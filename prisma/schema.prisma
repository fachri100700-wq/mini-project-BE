// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                  String        @id @default(uuid())

  firstName           String        @db.VarChar(25)
  lastName            String?       @db.VarChar(25)
  email               String        @unique
  password            String

  referredBy          String

  // Relation
  referral_points     ReferralPoint[]
  booking             Booking[]
  review              Review[]
  transactions        Transaction[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("customers")
}

model Organizer {
  id                  String        @id @default(uuid())

  organizerName       String        @db.VarChar(25)
  email               String        @unique
  phonenumber         String        @db.VarChar(15)
  personInCharge      String        @db.VarChar(25)
  address             String        @db.VarChar(100)
  password            String

  // Relation
  event               Event[]
  promo               Promotion[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("organizers")
}

model Event {
  id                  String        @id @default(uuid())

  eventName           String        @db.VarChar(100)
  eventDate           DateTime
  location            String        @db.VarChar(100)
  description         String        @db.VarChar(150)
  seatTotal           Int

  eventType           EventType
  eventCategory       EventCategory

  organizerId         String

  // Relation
  organizer           Organizer     @relation(fields: [organizerId], references: [id])
  ticketType          TicketType[]
  booking             Booking[]
  promotion           Promotion[]
  review              Review[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("events")
}

model TicketType {
  id                  String        @id @default(uuid())

  ticketType          String        @db.VarChar(10)
  price               Int
  seatAvailable       Int

  // Relation
  event               Event[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("ticket_types")
}

enum EventType {
  FREE
  PAID
}

enum EventCategory {
  KONSER
  SEMINAR
  LOREM
  IPSUM
}

model Promotion {
  id                  String        @id @default(uuid())

  promoName           String        @db.VarChar(25)
  promoStartDate      DateTime
  promoEndDate        DateTime
  quota               Int
  discAmount          Int

  eventId             String
  organizerId         String

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  organizer           Organizer     @relation(fields: [organizerId], references: [id])
  booking             Booking[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("promotions")
}

model Booking {
  id                  String        @id @default(uuid())

  eventId             String
  customerId          String
  promoId             String
  referralId          String

  quantity            Int
  totalPrice          Int

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  customer            Customer      @relation(fields: [customerId], references: [id])
  promo               Promotion     @relation(fields: [promoId], references: [id])
  referral            ReferralPoint @relation(fields: [referralId], references: [id])
  transactions        Transaction[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("bookings")
}

model Transaction {
  id                  String        @id @default(uuid())

  bookingId           String
  customerId          String
  amountPaid          Int

  // Relation
  booking             Booking       @relation(fields: [bookingId], references: [id])       
  customer            Customer      @relation(fields: [customerId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("transactions")
}

model ReferralPoint {
  id                  String        @id @default(uuid())

  code                String        @default(uuid())
  points              Int
  startDate           DateTime
  expireDate          DateTime

  customerId          String

  // Relation
  customer            Customer      @relation(fields: [customerId], references: [id])
  booking             Booking[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("referral_points")
}

model Review {
  id                  String        @id @default(uuid())

  eventId             String
  customerId          String

  feedback            String        @db.VarChar(100)
  rating              Int

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  customer            Customer      @relation(fields: [customerId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("reviews")
}