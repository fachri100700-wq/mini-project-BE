// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(uuid())

  username            String        @db.VarChar(25)
  email               String        @unique
  password            String
  
  // Referral Identity
  referralCode        String        @unique @db.VarChar(12)
  
  referredById        String?

  referredBy          User?         @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]        @relation("UserReferrals")

  // Organizer profile
  displayName         String?       @db.VarChar(50)
  bio                 String?       @db.VarChar(150)
  avatarUrl           String?
  location            String?       @db.VarChar(50)

  role                Role

  // Relation
  referralRewards     ReferralReward[]
  coupons             Coupon[]
  event               Event[]
  booking             Booking[]
  review              Review[]
  transactions        Transaction[]
  promo               Promotion[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("users")
}

enum Role {
  customer
  organizer
}

model Event {
  id            String              @id @default(uuid())

  eventName     String              @db.VarChar(100)
  startDate     DateTime
  endDate       DateTime
  imageUrl      String?
  location      String              @db.VarChar(100)
  description   String              @db.VarChar(150)
  seatTotal     Int

  eventType     EventType
  eventCategory EventCategory

  userId        String

  // Relation
  user          User                @relation(fields: [userId], references: [id])
  ticketType    TicketType[]
  booking       Booking[]
  promotion     Promotion[]
  review        Review[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  @@map("events")
}

model TicketType {
  id            String   @id @default(uuid())

  ticketType    String   @db.VarChar(10)
  price         Int
  seatAvailable Int

  eventId       String

  event         Event    @relation(fields: [eventId], references: [id])
  booking       Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@map("ticket_types")
}

enum EventType {
  FREE
  PAID
}

enum EventCategory {
  CONCERT
  SEMINAR
  SPORTS
  WORKSHOP
  EXHIBITION
  THEATER
  FESTIVAL
  OTHER
}

model Promotion {
  id                  String        @id @default(uuid())

  promoName           String        @db.VarChar(25)
  promoStartDate      DateTime
  promoEndDate        DateTime
  quota               Int
  discAmount          Int

  eventId             String
  userId              String

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  user                User          @relation(fields: [userId], references: [id])
  booking             Booking[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("promotions")
}

model Booking {
  id                  String        @id @default(uuid())

  eventId             String
  userId              String
  ticketTypeId        String
  promoId             String?

  quantity            Int
  totalPrice          Int

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  user                User          @relation(fields: [userId], references: [id])
  ticketType          TicketType    @relation(fields: [ticketTypeId], references: [id])
  promo               Promotion?    @relation(fields: [promoId], references: [id])
  transactions        Transaction[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("bookings")
}

model Transaction {
  id                  String        @id @default(uuid())

  bookingId           String
  userId              String
  amountPaid          Int
  expiry              DateTime
  transactionStatus   TransactionStatus   @default(WAITING_FOR_PAYMENT)
  paymentProof        String?

  // Relation
  booking             Booking       @relation(fields: [bookingId], references: [id])       
  user                User          @relation(fields: [userId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("transactions")
}

enum TransactionStatus {
  WAITING_FOR_PAYMENT
  WAITING_FOR_ADMIN_CONFIRMATION
  DONE
  REJECTED
  EXPIRED
  CANCELED
}

model ReferralReward {
  id                  String        @id @default(uuid())

  userId              String
  points              Int

  reason              ReferralRewardReason

  startDate           DateTime
  expireDate          DateTime

  // Relation
  user                User      @relation(fields: [userId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("referral_rewards")
}

enum ReferralRewardReason {
  REFERRED_USER
  USED_REFERRAL
  BONUS
}

model Coupon {
  id                  String        @id @default(uuid())

  code                String        @unique @db.VarChar(20)
  discount            Int
  expiredDate         DateTime

  userId              String
  user                User          @relation(fields: [userId], references: [id])

  isUsed              Boolean       @default(false)
  usedAt              DateTime?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("coupons")
}

model Review {
  id                  String        @id @default(uuid())

  eventId             String
  userId              String

  feedback            String        @db.VarChar(100)
  rating              Int

  // Relation
  event               Event         @relation(fields: [eventId], references: [id])
  user                User          @relation(fields: [userId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@map("reviews")
}